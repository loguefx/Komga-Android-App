<?xml version="1.0" encoding="utf-8"?>
<!--
    Komga adaptive icon foreground – 108dp canvas, safe zone 18–90dp
    Design: open manga book, left page has 3 panel grid, right page has stylised K
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── BOOK SHADOW ──────────────────────────────────────────────────── -->
    <path
        android:fillColor="#44000000"
        android:pathData="M22,84 Q54,90 86,84 L86,88 Q54,94 22,88 Z"/>

    <!-- ── LEFT PAGE (white, slight perspective) ───────────────────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M20,28 L52,23 L52,83 L20,87 Z"/>

    <!-- Left-edge depth shadow -->
    <path
        android:fillColor="#D8D8D8"
        android:pathData="M20,28 L23,28 L23,87 L20,87 Z"/>

    <!-- ── RIGHT PAGE (off-white) ───────────────────────────────────────── -->
    <path
        android:fillColor="#F2F2F2"
        android:pathData="M56,23 L88,28 L88,87 L56,83 Z"/>

    <!-- Right-edge depth shadow -->
    <path
        android:fillColor="#DDDDDD"
        android:pathData="M85,28 L88,28 L88,87 L85,87 Z"/>

    <!-- ── BOOK BOTTOM CURVE ─────────────────────────────────────────────── -->
    <path
        android:fillColor="#CCCCCC"
        android:pathData="M20,87 Q54,93 88,87 L88,89 Q54,95 20,89 Z"/>

    <!-- ── BOOK TOP HIGHLIGHT ──────────────────────────────────────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M20,28 Q54,22 88,28 L88,30 Q54,24 20,30 Z"/>

    <!-- ── MANGA PANELS – LEFT PAGE ──────────────────────────────────────── -->
    <!-- Top panel (large horizontal) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#BBBBBB"
        android:strokeWidth="1.8"
        android:pathData="M25,31 L48,27.5 L48,50 L25,53 Z"/>

    <!-- Bottom-left panel -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#BBBBBB"
        android:strokeWidth="1.8"
        android:pathData="M25,55.5 L36,54 L36,77 L25,78 Z"/>

    <!-- Bottom-right panel -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#BBBBBB"
        android:strokeWidth="1.8"
        android:pathData="M38.5,53.5 L48,52 L48,76.5 L38.5,77.5 Z"/>

    <!-- ── K LETTER – RIGHT PAGE ──────────────────────────────────────────
         Split into 3 segments to create a purple→blue→cyan colour flow     -->

    <!-- Vertical stem (deep purple) -->
    <path
        android:fillColor="#7C5CFC"
        android:pathData="M61,29 L67,29 L67,79 L61,79 Z"/>

    <!-- Upper arm (indigo-blue) -->
    <path
        android:fillColor="#4D8EFF"
        android:pathData="M67,53 L82,29.5 L76,29 L63,52 Z"/>

    <!-- Lower arm (cyan) -->
    <path
        android:fillColor="#00CFEE"
        android:pathData="M67,54 L82,78 L76,78.5 L63,55 Z"/>

    <!-- ── SPINE GLOW (cyan) ─────────────────────────────────────────────── -->
    <path
        android:fillColor="#00D4FF"
        android:fillAlpha="0.9"
        android:pathData="M52,21 L56,21 L56,84 L52,84 Z"/>

    <!-- Spine base glow -->
    <path
        android:fillColor="#00D4FF"
        android:fillAlpha="0.5"
        android:pathData="M38,88 Q54,93 70,88 L70,90 Q54,95 38,90 Z"/>

</vector>
